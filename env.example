# Discogs API Configuration
# Get your API token from: https://www.discogs.com/settings/developers
DISCOGS_API_TOKEN=your_discogs_api_token_here
DISCOGS_USERNAME=your_discogs_username_here

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Security (Optional)
# Set a secure random token to protect /api/performance endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty in development to allow unrestricted access
ADMIN_TOKEN=

# Instructions:
# 1. Copy this file to .env.local: cp env.example .env.local
# 2. Replace the placeholder values with your actual credentials
# 3. Generate a secure ADMIN_TOKEN for production deployments
# 4. Never commit .env.local to version control
